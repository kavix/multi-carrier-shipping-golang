# Example environment variables for local development.
# Copy this to a `.env` file and fill in secrets (do NOT commit `.env`).

# Kafka brokers
KAFKA_BROKERS=kafka:29092

# Notification service SMTP settings
# Recommended SMTP (Yahoo): smtp.mail.yahoo.com port 465 or 587
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=465
SMTP_FROM=yourname@example.com
SMTP_USER=youremail@example.com
SMTP_PASSWORD=replace_with_real_password
# API Gateway
PORT=8080
SHIPMENT_SERVICE_URL=http://localhost:8081
CARRIER_SERVICE_URL=http://localhost:8082
RATE_SERVICE_URL=http://localhost:8083
LABEL_SERVICE_URL=http://localhost:8084
TRACKING_SERVICE_URL=http://localhost:8085
ADDRESS_SERVICE_URL=http://localhost:8086
BILLING_SERVICE_URL=http://localhost:8087
RETURN_SERVICE_URL=http://localhost:8088

# Kafka
KAFKA_BROKERS=localhost:9092

# DHL API (replace with real credentials)
DHL_API_KEY=your-dhl-api-key
DHL_API_SECRET=your-dhl-api-secret

# FedEx API (replace with real credentials)
FEDEX_API_KEY=your-fedex-api-key
FEDEX_API_SECRET=your-fedex-api-secret

# UPS API (replace with real credentials)
UPS_API_KEY=your-ups-api-key
UPS_API_SECRET=your-ups-api-secret

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_your_key

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
